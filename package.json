{
  "name": "obsidian-extended-properties",
  "version": "4.0.3",
  "description": "Obsidian plugin: a configurable properties sidebar with derived numbers, dice rolling and per-type layouts.",
  "main": "main.js",
  "author": "electroluminescent",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "i18n": "node scripts/i18n-check.mjs"
  },
  "keywords": [
    "obsidian",
    "dnd",
    "ttrpg"
  ],
  "license": "MIT",
  "devDependencies": {
    "@codemirror/language": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "esbuild": "^0.21.5",
    "obsidian": "latest",
    "typescript": "^5.4.5",
    "vitest": "^1.6.1"
  }
}
